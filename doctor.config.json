{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "files": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.next/**",
      "**/.expo/**",
      "**/.opencode/**",
      "**/coverage/**",
      "**/generated/**"
    ],
    "overrides": [
      {
        "files": ["package.json"],
        "rules": ["deslop/unused-dev-dependency"]
      }
    ]
  }
}

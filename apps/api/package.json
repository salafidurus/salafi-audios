  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "oxlint . && eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:prepush": "vitest run --changed=origin/main",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "openapi:json": "pnpm build && node dist/openapi.js",
    "preopenapi:json": "pnpm --filter @sd/core-db prisma:generate",
    "openapi": "pnpm openapi:json"
  },

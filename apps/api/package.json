  "scripts": {
    "format": "oxfmt src test",
    "start": "bun --bun src/main.ts",
    "start:dev": "bun --bun --watch src/main.ts",
    "dev": "bun --bun --watch src/main.ts",
    "start:debug": "bun --bun --inspect-brk --watch src/main.ts",
    "start:prod": "NODE_ENV=production bun --bun src/main.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "bun test --path-ignore-patterns 'e2e/'",
    "test:watch": "bun test --watch --path-ignore-patterns 'e2e/'",
    "test:cov": "bun test --coverage --path-ignore-patterns 'e2e/'",
    "test:prepush": "bun test --path-ignore-patterns 'e2e/'",
    "test:e2e": "bun test ./e2e/admin-permissions.spec-e2e.ts ./e2e/app.spec-e2e.ts ./e2e/auth.spec-e2e.ts ./e2e/infrastructure.spec-e2e.ts ./e2e/public-api.spec-e2e.ts ./e2e/user-flows.spec-e2e.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },

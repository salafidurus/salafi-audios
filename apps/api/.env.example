# Local API env template.
# Copy to one of:
# - .env
# - .env.local
# - .env.development.local

NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Direct database URL required by the API env schema.
DATABASE_URL=postgresql://sd_dev:password@localhost:5432/salafi_dev?schema=public

# Optional CDN base URL for public media.
ASSET_CDN_BASE_URL=https://cdn.example.com

# Canonical web origin for sitemap <loc> URLs (production only).
# Example: https://www.salafidurus.com
SITEMAP_BASE_URL=

# Better Auth
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:4000
COOKIE_DOMAIN=localhost

# OAuth
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
APPLE_CLIENT_ID=replace-me
APPLE_CLIENT_SECRET=replace-me

# R2 Account Details
R2_ACCOUNT_ID=replace-me
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET_NAME=replace-me
R2_PUBLIC_BASE_URL=replace-me

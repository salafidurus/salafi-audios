{
  // Editor / typecheck only — does not emit. NestJS CLI uses tsconfig.build.json.
  "extends": "../../tsconfig.nest.json",
  "compilerOptions": {
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vitest/globals", "node", "bun-types"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "test/**/*.ts"]
}

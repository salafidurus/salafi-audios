{
  "extends": "../../tsconfig.packages.json",
  "compilerOptions": {
    // Next.js handles JSX transformation via SWC; TS should not transform it
    "jsx": "preserve",
    "moduleSuffixes": [".desktop.web", ".web", "", ".native"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}

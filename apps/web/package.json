{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "RUST_BACKTRACE=1 bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "oxlint . && eslint .",
    "test": "bun run vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:prepush": "vitest run --changed=origin/main",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "playwright:version": "playwright --version",
    "playwright:install": "playwright install --with-deps",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sd/core-api": "workspace:*",
    "@sd/core-contracts": "workspace:*",
    "@sd/core-i18n": "workspace:*",
    "@sd/design-tokens": "workspace:*",
    "@sd/domain-account": "workspace:*",
    "@sd/domain-audio": "workspace:*",
    "@sd/domain-content": "workspace:*",
    "@sd/domain-live": "workspace:*",
    "@sd/domain-search": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "better-auth": "catalog:",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "i18next": "catalog:",
    "lucide-react": "^1.21.0",
    "next": "16.2.7",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "tailwindcss": "^4"
  }
}

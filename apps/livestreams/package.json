{
  "name": "livestreams",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "dev": "nest start --watch",
    "lint": "oxlint . && eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:prepush": "vitest run --changedSince=origin/main",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "gen:telegram:session": "node scripts/gen-telegram-session.mjs"
  },
  "dependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/terminus": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@sd/core-contracts": "workspace:*",
    "@sd/core-db": "workspace:*",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "dotenv": "^17.4.2",
    "helmet": "catalog:",
    "pg": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "telegram": "^2.26.16",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "catalog:",
    "@eslint/js": "catalog:",
    "@nestjs/cli": "catalog:",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "^26.0.0",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "source-map-support": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "typescript": "^5.9.0",
    "typescript-eslint": "catalog:"
  }
}

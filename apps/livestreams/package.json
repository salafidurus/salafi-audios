{
  "name": "livestreams",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "dev": "nest start --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:cov": "jest --coverage",
    "test:prepush": "jest --changedSince=origin/main --passWithNoTests",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest.js --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "gen:telegram:session": "node scripts/gen-telegram-session.mjs"
  },
  "dependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/terminus": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@sd/core-contracts": "workspace:*",
    "@sd/core-db": "workspace:*",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "dotenv": "^17.4.2",
    "helmet": "^8.1.0",
    "pg": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "telegram": "^2.26.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "catalog:",
    "@sd/util-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/jest": "catalog:",
    "@types/node": "^22.10.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "jest": "catalog:",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "catalog:",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.53.1"
  }
}

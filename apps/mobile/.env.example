# Local Expo / EAS env template.
# Copy to .env.local for local Expo work.

APP_ENV=development
EXPO_PUBLIC_API_URL=http://localhost:3000

# Sentry / Vexo
SENTRY_AUTH_TOKEN=not-needed-for-dev
EXPO_PUBLIC_SENTRY_DSN=https://notNeededPublicKey@o0.ingest.sentry.io/0
EXPO_PUBLIC_SENTRY_ORG=not-needed-for-dev
EXPO_PUBLIC_SENTRY_PROJECT=not-needed-for-dev
EXPO_PUBLIC_VEXO_PROJECT_ID=not-needed-for-dev

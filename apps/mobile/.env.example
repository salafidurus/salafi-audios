# Local Expo / EAS env template.
# Copy to .env.local for local Expo work.

APP_ENV=development
EXPO_PUBLIC_API_URL=http://10.0.2.2:3001

# Sentry / Vexo
SENTRY_AUTH_TOKEN=replace-me
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
EXPO_PUBLIC_SENTRY_ORG=replace-me
EXPO_PUBLIC_SENTRY_PROJECT=replace-me
EXPO_PUBLIC_VEXO_PROJECT_ID=replace-me

  "type": "module",
  "main": "index.js",
  "scripts": {
    "eas-build-post-install": "cd ../.. && turbo run build --filter=native^...",
    "eas-build-on-error": "sentry-eas-build-on-error",
    "start": "expo start --dev-client",
    "dev": "expo start --dev-client",

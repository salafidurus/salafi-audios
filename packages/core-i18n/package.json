{
  "name": "@sd/core-i18n",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./locales/*": {
      "types": "./src/locales/*",
      "default": "./dist/locales/*"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --format esm,cjs --dts --tsconfig tsconfig.build.json --out-dir dist && node -e \"require('fs').cpSync('src/locales', 'dist/locales', {recursive:true})\"",
    "dev": "pnpm build --watch",
    "lint": "node ../../node_modules/eslint/bin/eslint.js .",
    "test": "node ../../node_modules/jest/bin/jest.js --passWithNoTests",
    "test:watch": "node ../../node_modules/jest/bin/jest.js --watch",
    "test:cov": "node ../../node_modules/jest/bin/jest.js --coverage",
    "test:prepush": "node ../../node_modules/jest/bin/jest.js --changedSince=origin/main --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sd/core-contracts": "workspace:*",
    "i18next": "^23.7.6"
  },
  "devDependencies": {
    "@sd/util-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.4.11",
    "tsup": "^8.0.0"
  }
}

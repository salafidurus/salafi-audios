{
  "name": "@sd/core-i18n",
  "version": "0.0.0",
  "private": true,
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./locales/*": "./src/locales/*"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --format esm,cjs --dts --tsconfig tsconfig.build.json --out-dir dist && node -e \"require('fs').cpSync('src/locales', 'dist/locales', {recursive:true})\"",
    "dev": "bun run build --watch",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:prepush": "vitest run --changed=origin/main",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sd/core-contracts": "workspace:*",
    "i18next": "catalog:"
  },
  "devDependencies": {
    "rimraf": "catalog:",
    "tsup": "catalog:"
  }
}

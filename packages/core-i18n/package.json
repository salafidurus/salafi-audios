{
  "name": "@sd/core-i18n",
  "version": "0.0.0",
  "private": true,
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./locales/*": "./src/locales/*"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --format esm,cjs --dts --tsconfig tsconfig.build.json --out-dir dist && node -e \"require('fs').cpSync('src/locales', 'dist/locales', {recursive:true})\"",
    "lint": "oxlint .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage",
    "test:prepush": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sd/core-contracts": "workspace:*",
    "i18next": "catalog:"
  },
  "devDependencies": {
    "rimraf": "catalog:",
    "tsup": "catalog:"
  }
}

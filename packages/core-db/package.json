{
  "name": "@sd/core-db",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./src/generated/prisma/client.d.ts",
      "import": "./dist/generated/prisma/client.js",
      "require": "./dist/generated/prisma/client.js"
    }
  },
  "scripts": {
    "lint": "oxlint . && eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:prepush": "vitest run --changedSince=origin/main",
    "pretypecheck": "pnpm prisma:generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma --config=./prisma.config.ts && node ./scripts/copy-generated-to-dist.js",
    "prisma:format": "prisma format --schema=./prisma/schema.prisma --config=./prisma.config.ts",
    "prisma:validate": "prisma validate --schema=./prisma/schema.prisma --config=./prisma.config.ts",
    "migrate:create-only": "node ./scripts/migrate-with-auto-name.js",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma --config=./prisma.config.ts",
    "make-admin": "node ./scripts/make-admin.js",
    "build": "pnpm prisma:generate && tsup src/index.ts --format esm,cjs --out-dir dist && node ./scripts/copy-generated-to-dist.js && tsc -p tsconfig.build.json",
    "dev": "pnpm build --watch"
  },
  "dependencies": {
    "@prisma/client": "catalog:",
    "@prisma/client-runtime-utils": "^7.3.0",
    "@sd/core-contracts": "workspace:*"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.0.0",
    "prisma": "^7.3.0",
    "tsup": "catalog:"
  }
}

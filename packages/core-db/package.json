{
  "name": "@sd/core-db",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./src/generated/prisma/client.d.ts",
      "import": "./dist/generated/prisma/client.js",
      "require": "./dist/generated/prisma/client.js"
    }
  },
  "scripts": {
    "lint": "oxlint .",
    "pretest": "bun run prisma:generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "pretest:prepush": "bun run prisma:generate",
    "test:prepush": "vitest run --changed=origin/main",
    "pretypecheck": "bun run prisma:generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma --config=./prisma.config.ts && bun ./scripts/copy-generated-to-dist.js",
    "prisma:format": "prisma format --schema=./prisma/schema.prisma --config=./prisma.config.ts",
    "prisma:validate": "prisma validate --schema=./prisma/schema.prisma --config=./prisma.config.ts",
    "prisma:seed": "bun run scripts/seed.ts",
    "migrate:create-only": "bun ./scripts/migrate-with-auto-name.js",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma --config=./prisma.config.ts",
    "grant:role": "bun ./scripts/grant-role.js",
    "grant:permission": "bun ./scripts/grant-permission.js",
    "build": "bun run prisma:generate && tsup src/index.ts --format esm,cjs --out-dir dist && bun ./scripts/copy-generated-to-dist.js && tsc -p tsconfig.build.json",
    "dev": "bun run build --watch"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@prisma/client-runtime-utils": "^7.3.0",
    "@sd/core-contracts": "workspace:*"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.0.0",
    "prisma": "^7.3.0",
    "tsup": "catalog:"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  }
}

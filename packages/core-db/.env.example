# Local Prisma / DB env template.
# Used by core-db scripts with precedence:
# .env -> .env.local -> .env.<NODE_ENV> -> .env.<NODE_ENV>.local

# Direct DB URL required for migrations / prisma generate.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# Optional runtime DB URL if you separate pooled vs direct connections.
DIRECT_DB_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# Optional shadow DB for Prisma workflows that require it.
SHADOW_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME_shadow?sslmode=require

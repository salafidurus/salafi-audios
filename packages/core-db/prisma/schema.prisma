// packages/core-db/prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

//////////////////////////
// Enums
//////////////////////////

enum UserRole {
  listener // Default role - regular authenticated user
  scholar // Content creator
  translator // Language translator
  editor // Content editor
  admin // Platform administrator
  superadmin // Full system access
}

enum Permission {
  // Scholar Permissions
  SCHOLARS_VIEW
  SCHOLARS_CREATE
  SCHOLARS_EDIT
  SCHOLARS_DELETE
  SCHOLARS_PUBLISH

  // Listing Permissions (Collections, Series, Singles, Modules, Lessons)
  LISTINGS_VIEW
  LISTINGS_CREATE
  LISTINGS_EDIT
  LISTINGS_DELETE
  LISTINGS_PUBLISH

  // Topic Permissions
  TOPICS_VIEW
  TOPICS_CREATE
  TOPICS_EDIT
  TOPICS_DELETE
  TOPICS_PUBLISH

  // Translation Permissions
  TRANSLATIONS_VIEW
  TRANSLATIONS_CREATE
  TRANSLATIONS_EDIT
  TRANSLATIONS_DELETE
  TRANSLATIONS_PUBLISH

  // Media Permissions
  MEDIA_UPLOAD
  MEDIA_DELETE

  // User Management Permissions
  USERS_VIEW
  USERS_EDIT
  USERS_DELETE
  USERS_GRANT_PERMISSIONS
  USERS_GRANT_ROLES
}

enum ScholarPermissionType {
  OWN_CONTENT
  ASSIGNED_EDITOR
}

enum Status {
  draft
  review
  published
  archived
}

enum ListingFormat {
  collection
  series
  single
}

enum RecommendationRecurrence {
  none
  yearly
}

enum ScholarRole {
  scholar
  scholar_editor
}

enum Locale {
  en
  ar
}

enum TranslationStatus {
  draft
  published
}

enum ScholarTitle {
  allamah
  sheikh
  ustadh
  akh
}

//////////////////////////
// Ingestion batch (for seed/dummy dataset lifecycle)
//////////////////////////

model IngestionBatch {
  id          String   @id @default(cuid())
  tag         String
  environment String
  createdAt   DateTime @default(now())

  scholars    Scholar[]    @relation("IngestBatchScholars")
  listings    Listing[]    @relation("IngestBatchListings")
  audioAssets AudioAsset[] @relation("IngestBatchAudioAssets")

  @@unique([tag, environment])
  @@index([tag])
  @@index([environment])
}

//////////////////////////
// Users & Roles
//////////////////////////

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?

  // Domain extensions
  preferredLanguage Locale?

  // Relations
  sessions Session[]
  accounts Account[]

  // Role and Permission Management
  roles                  UserRoleAssignment[]
  roleAssignmentsGranted UserRoleAssignment[] @relation("UserRoleGranter")
  permissions            UserPermission[]
  permissionsGranted     UserPermission[]     @relation("UserPermissionGranter")

  // Scholar and Translator Management
  scholarRoles           UserScholarRole[]
  createdScholarRoles    UserScholarRole[]    @relation("createdByUser")
  translatorRoles        UserTranslatorRole[]
  createdTranslatorRoles UserTranslatorRole[] @relation("createdByUser")

  // Content Management
  progress  UserListingProgress[]
  favorites FavoriteListing[]
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  role      UserRole
  grantedAt DateTime @default(now())
  grantedBy String?

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser User? @relation("UserRoleGranter", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
}

model UserPermission {
  id         String     @id @default(cuid())
  userId     String
  permission Permission
  grantedAt  DateTime   @default(now())
  grantedBy  String?

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser User? @relation("UserPermissionGranter", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([userId, permission])
  @@index([userId])
  @@index([permission])
}

model UserScholarRole {
  id             String                @id @default(cuid())
  userId         String
  scholarId      String
  permissionType ScholarPermissionType
  createdAt      DateTime              @default(now())
  createdBy      String?

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholar       Scholar @relation(fields: [scholarId], references: [id], onDelete: Cascade)
  createdByUser User?   @relation("createdByUser", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([userId, scholarId, permissionType])
  @@index([scholarId, permissionType], map: "idx_user_scholar_role_scholar_permission")
  @@index([userId], map: "idx_user_scholar_role_user")
}

model UserTranslatorRole {
  id         String   @id @default(cuid())
  userId     String
  locale     Locale
  canPublish Boolean  @default(false)
  createdAt  DateTime @default(now())
  createdBy  String?

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("createdByUser", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([userId, locale])
  @@index([userId])
  @@index([locale])
}

//////////////////////////
// Scholars
//////////////////////////

model Scholar {
  id           String        @id @default(cuid())
  slug         String
  name         String
  bio          String?
  country      String        @default("SA")
  mainLanguage Locale        @default(ar)
  imageUrl     String?
  isActive     Boolean       @default(true)
  isKibar      Boolean       @default(false)
  isFeatured   Boolean       @default(false)
  title        ScholarTitle?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Decoupled audit columns
  createdBy String? @db.Uuid
  updatedBy String? @db.Uuid
  deletedBy String? @db.Uuid

  // Social links
  socialTwitter   String?
  socialTelegram  String?
  socialYoutube   String?
  socialWebsite   String?
  socialFacebook  String?
  socialInstagram String?

  ingestionBatchId String?
  ingestionBatch   IngestionBatch? @relation("IngestBatchScholars", fields: [ingestionBatchId], references: [id])

  listings     Listing[]
  userRoles    UserScholarRole[]
  translations ScholarTranslation[]

  @@unique([slug], map: "uq_scholar_slug")
  @@index([isActive], map: "idx_scholar_active")
}

//////////////////////////
// Listings
//////////////////////////

model Listing {
  id                       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scholarId                String
  parentId                 String?       @db.Uuid
  slug                     String        @unique
  title                    String
  description              String?
  format                   ListingFormat
  coverImageUrl            String?
  language                 Locale?
  status                   Status        @default(draft)
  publishedAt              DateTime?
  orderIndex               Int?
  durationSeconds          Int?
  publishedLectureCount    Int?
  publishedDurationSeconds Int?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime?     @updatedAt

  deletedAt     DateTime?
  deleteAfterAt DateTime?

  // Decoupled audit columns
  createdBy String? @db.Uuid
  updatedBy String? @db.Uuid
  deletedBy String? @db.Uuid

  ingestionBatchId String?
  ingestionBatch   IngestionBatch? @relation("IngestBatchListings", fields: [ingestionBatchId], references: [id])

  scholar              Scholar               @relation(fields: [scholarId], references: [id], onDelete: Restrict)
  parent               Listing?              @relation("ListingHierarchy", fields: [parentId, scholarId], references: [id, scholarId], onDelete: Restrict)
  children             Listing[]             @relation("ListingHierarchy")
  audioAssets          AudioAsset[]
  topics               ListingTopic[]
  progress             UserListingProgress[]
  favorites            FavoriteListing[]
  translations         ListingTranslation[]
  curationMetadata     CurationMetadata?
  recommendationHeroes RecommendationHero[]

  @@unique([id, scholarId])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([parentId])
  @@index([scholarId, status])
  @@index([scholarId, format])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([deleteAfterAt])
  @@index([orderIndex])
}

model CurationMetadata {
  id         String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId  String                   @unique @db.Uuid
  override   Boolean                  @default(false)
  startAt    DateTime?
  endAt      DateTime?
  recurrence RecommendationRecurrence @default(none)
  listing    Listing                  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model RecommendationHero {
  id         String    @id @default(cuid())
  listingId  String    @db.Uuid
  headline   String
  orderIndex Int       @default(0)
  isActive   Boolean   @default(true)
  startAt    DateTime?
  endAt      DateTime?
  createdAt  DateTime  @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([isActive, orderIndex], map: "idx_recommendationhero_active_order")
  @@index([listingId], map: "idx_recommendationhero_listing")
}

//////////////////////////
// AudioAssets
//////////////////////////

model AudioAsset {
  id              String   @id @default(cuid())
  listingId       String   @db.Uuid
  url             String
  format          String?
  bitrateKbps     Int?
  sizeBytes       BigInt?
  durationSeconds Int?
  source          String?
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())

  ingestionBatchId String?
  ingestionBatch   IngestionBatch? @relation("IngestBatchAudioAssets", fields: [ingestionBatchId], references: [id])

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId], map: "idx_audioasset_listing")
}

//////////////////////////
// Topics & join tables
//////////////////////////

model Topic {
  id        String   @id @default(cuid())
  slug      String
  name      String
  createdAt DateTime @default(now())

  listingTopics ListingTopic[]
  translations  TopicTranslation[]

  @@unique([slug], map: "uq_topic_slug")
}

model ListingTopic {
  listingId String   @db.Uuid
  topicId   String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  topic   Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([listingId, topicId])
  @@index([topicId, listingId], map: "idx_listingtopic_topic_listing")
}

//////////////////////////
// Progress & Favorites
//////////////////////////

model UserListingProgress {
  userId          String
  listingId       String   @db.Uuid
  positionSeconds Int      @default(0)
  isCompleted     Boolean  @default(false)
  updatedAt       DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@index([userId, updatedAt], map: "idx_progress_user_updatedat")
  @@index([listingId], map: "idx_progress_listing")
}

model FavoriteListing {
  userId    String
  listingId String   @db.Uuid
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@index([userId, createdAt], map: "idx_fav_user_createdat")
  @@index([listingId], map: "idx_fav_listing")
}

//////////////////////////
// better-auth tables
//////////////////////////

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ScholarTranslation {
  id        String            @id @default(cuid())
  scholarId String
  locale    Locale
  status    TranslationStatus @default(draft)
  name      String
  bio       String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  scholar Scholar @relation(fields: [scholarId], references: [id], onDelete: Cascade)

  @@unique([scholarId, locale])
  @@index([scholarId])
}

model ListingTranslation {
  id          String            @id @default(cuid())
  listingId   String            @db.Uuid
  locale      Locale
  status      TranslationStatus @default(draft)
  title       String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, locale])
  @@index([listingId])
}

model TopicTranslation {
  id        String            @id @default(cuid())
  topicId   String
  locale    Locale
  status    TranslationStatus @default(draft)
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, locale])
  @@index([topicId])
}

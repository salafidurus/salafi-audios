# Local ingest env template.
# Copy to .env.local when running ingest commands.

DATABASE_URL=postgresql://sd_dev:password@localhost:5432/salafi_dev?schema=public
DIRECT_DB_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

R2_ACCOUNT_ID=replace-me
R2_BUCKET=replace-me
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_PUBLIC_BASE_URL=https://cdn.example.com

# Optional ingest flags
INGEST_TAG=
INGEST_ENVIRONMENT=development
INGEST_DRY_RUN=false
INGEST_STRICT_AUDIO_UPLOAD=false
INGEST_SKIP_R2_DELETE=false
INGEST_AUDIO_DIR=

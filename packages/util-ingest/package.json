{
  "name": "@sd/util-ingest",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --format esm,cjs --dts --tsconfig tsconfig.build.json --out-dir dist",
    "dev": "pnpm build --watch",
    "fix:series-collections": "tsx src/commands/fix-series-collections.ts",
    "fix:recommendation-hero": "tsx src/commands/fix-recommendation-hero.ts",
    "ingest:content": "tsx src/commands/ingest-content.ts",
    "ingest:remove": "tsx src/commands/remove-content.ts",
    "convert:supabase": "tsx src/commands/convert-supabase.ts",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:prepush": "jest --changedSince=origin/main --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1072.0",
    "@prisma/adapter-pg": "catalog:",
    "@sd/core-db": "workspace:*",
    "dotenv": "^16.4.5",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@sd/util-config": "workspace:*",
    "@types/jest": "catalog:",
    "@types/node": "^22.0.0",
    "jest": "catalog:",
    "rimraf": "^6.0.0",
    "ts-jest": "catalog:",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0"
  }
}

{
  "name": "@sd/util-ingest",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --format esm,cjs --dts --tsconfig tsconfig.build.json --out-dir dist",
    "dev": "pnpm build --watch",
    "fix:series-collections": "tsx src/commands/fix-series-collections.ts",
    "fix:recommendation-hero": "tsx src/commands/fix-recommendation-hero.ts",
    "ingest:content": "tsx src/commands/ingest-content.ts",
    "ingest:remove": "tsx src/commands/remove-content.ts",
    "convert:supabase": "tsx src/commands/convert-supabase.ts",
    "lint": "oxlint . && eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:prepush": "vitest run --changed=origin/main",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@sd/core-db": "workspace:*",
    "dotenv": "^16.4.5",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "tsx": "^4.22.4"
  }
}

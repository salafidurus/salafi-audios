{
  "name": "@sd/design-tokens",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./src/index.web.ts",
  "types": "./src/index.web.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.native.ts",
      "default": "./src/index.web.ts"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "pnpm build --watch",
    "lint": "node ../../node_modules/eslint/bin/eslint.js .",
    "test": "node ../../node_modules/jest/bin/jest.js --passWithNoTests",
    "test:prepush": "node ../../node_modules/jest/bin/jest.js --changedSince=origin/main --passWithNoTests",
    "test:watch": "node ../../node_modules/jest/bin/jest.js --watch --passWithNoTests",
    "test:cov": "node ../../node_modules/jest/bin/jest.js --coverage --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@sd/util-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.4.11"
  }
}

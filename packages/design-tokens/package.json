{
  "name": "@sd/design-tokens",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist",
    "dev": "pnpm build --watch",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@sd/config": "workspace:*",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0"
  }
}

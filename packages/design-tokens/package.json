{
  "name": "@sd/design-tokens",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "bun run build --watch",
    "lint": "oxlint .",
    "test": "bun test",
    "test:prepush": "vitest run --changed=origin/main",
    "test:watch": "bun test --watch",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "rimraf": "catalog:"
  }
}

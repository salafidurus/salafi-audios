{
  "extends": ["./tsconfig.json", "../../tsconfig.strict.json"],
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    // Must disable this for emitting builds
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}

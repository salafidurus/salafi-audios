{
  // Consumed as source by Expo and Next.js bundlers — never run directly by Node.
  // Extends canonical packages preset (ESNext + Bundler moduleResolution + noEmit).
  "extends": "../../tsconfig.packages.json",
  "compilerOptions": {
    "jsx": "react-native",
    // Project reference support for incremental builds
    "composite": true,
    "incremental": true,
    "types": ["bun-types", "node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}

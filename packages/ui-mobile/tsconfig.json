{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "src",
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleSuffixes": [".native", ".web", ""],
    "paths": {
      "@/*": ["*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src"]
}

{
  // NestJS/Node backend services: extend base.json (CommonJS runtime, not Bundler)
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    // Required for NestJS decorator-based dependency injection and metadata reflection
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    // emitDecoratorMetadata synthesises require() for type imports — incompatible with verbatimModuleSyntax
    "verbatimModuleSyntax": false
  }
}

{
  "compilerOptions": {
    // ES2023 enables Array.toSorted/toReversed/with and other modern built-ins
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "strict": true,
    // Skip .d.ts validation in node_modules — speeds up compilation significantly
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  }
}

{
  "name": "@sd/core-contracts",
  "version": "0.0.0",
  "private": true,
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./query": {
      "types": "./src/query/index.ts",
      "import": "./src/query/index.ts",
      "require": "./src/query/index.ts",
      "default": "./src/query/index.ts"
    },
    "./query/hooks": {
      "types": "./src/query/hooks/index.ts",
      "import": "./src/query/hooks/index.ts",
      "require": "./src/query/hooks/index.ts",
      "default": "./src/query/hooks/index.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "import": "./src/http.ts",
      "require": "./src/http.ts",
      "default": "./src/http.ts"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "lint": "oxlint .",
    "test": "bun test",
    "test:prepush": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "catalog:",
    "react": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "catalog:",
    "react": ">=18"
  }
}

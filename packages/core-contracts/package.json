{
  "name": "@sd/core-contracts",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "files": [
    "src",
    "dist"
  ],
  "types": "./src/index.ts",
  "main": "./dist/index.node.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.node.js",
      "default": "./src/index.ts"
    },
    "./query": {
      "types": "./src/query/index.ts",
      "import": "./dist/query/index.js",
      "require": "./dist/query/index.js",
      "default": "./dist/query/index.js"
    },
    "./query/hooks": {
      "types": "./src/query/hooks/index.ts",
      "import": "./dist/query/hooks/index.js",
      "require": "./dist/query/hooks/index.js",
      "default": "./dist/query/hooks/index.js"
    },
    "./http": {
      "types": "./src/http.ts",
      "import": "./dist/http.js",
      "require": "./dist/http.js",
      "default": "./dist/http.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "test:prepush": "jest --changedSince=origin/main --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:watch": "jest --watch --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.69.0"
  },
  "devDependencies": {
    "@sd/util-config": "workspace:*",
    "@types/react": "^19.2.9",
    "rimraf": "^6.0.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}

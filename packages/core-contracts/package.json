{
  "name": "@sd/core-contracts",
  "version": "0.0.0",
  "private": true,
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./node": {
      "types": "./dist/index.node.d.ts",
      "import": "./dist/index.node.mjs",
      "require": "./dist/index.node.js",
      "default": "./dist/index.node.mjs"
    },
    "./query": {
      "types": "./dist/query/index.d.ts",
      "import": "./dist/query/index.mjs",
      "require": "./dist/query/index.js",
      "default": "./dist/query/index.mjs"
    },
    "./query/hooks": {
      "types": "./dist/query/hooks/index.d.ts",
      "import": "./dist/query/hooks/index.mjs",
      "require": "./dist/query/hooks/index.js",
      "default": "./dist/query/hooks/index.mjs"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.mjs",
      "require": "./dist/http.js",
      "default": "./dist/http.mjs"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint .",
    "test": "bun test",
    "test:prepush": "vitest run --changed=origin/main",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:watch": "bun test --watch",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "catalog:",
    "react": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "catalog:",
    "react": ">=18"
  }
}

{
  "name": "@sd/core-contracts",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "files": [
    "src",
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./node": {
      "types": "./dist/index.node.d.ts",
      "import": "./dist/index.node.mjs",
      "require": "./dist/index.node.js",
      "default": "./dist/index.node.mjs"
    },
    "./query": {
      "types": "./dist/query/index.d.ts",
      "import": "./dist/query/index.mjs",
      "require": "./dist/query/index.js",
      "default": "./dist/query/index.mjs"
    },
    "./query/hooks": {
      "types": "./dist/query/hooks/index.d.ts",
      "import": "./dist/query/hooks/index.mjs",
      "require": "./dist/query/hooks/index.js",
      "default": "./dist/query/hooks/index.mjs"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.mjs",
      "require": "./dist/http.js",
      "default": "./dist/http.mjs"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "test:prepush": "jest --changedSince=origin/main --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:watch": "jest --watch --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@tanstack/react-query": "catalog:"
  },
  "devDependencies": {
    "@sd/util-config": "workspace:*",
    "@types/jest": "catalog:",
    "@types/node": "^22.10.7",
    "@types/react": "~19.2.14",
    "jest": "catalog:",
    "rimraf": "^6.0.0",
    "ts-jest": "catalog:",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}

{
  // NestJS/Node backend services: CommonJS runtime with Bun-compatible bundler resolution.
  // Updated for Bun compatibility while maintaining NestJS decorator requirements.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // NestJS CLI expects CommonJS output; Node10 resolution is the classic
    // Node.js resolution strategy compatible with CommonJS modules
    "module": "CommonJS",
    "moduleResolution": "Node10",
    // Required for NestJS decorator-based dependency injection and metadata reflection
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // esModuleInterop inherited from base, but explicit here for CommonJS interop
    "esModuleInterop": true,
    // emitDecoratorMetadata synthesises require() for type imports — incompatible with verbatimModuleSyntax
    "verbatimModuleSyntax": false
  }
}

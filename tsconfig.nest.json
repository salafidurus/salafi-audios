{
  // NestJS/Node backend services: ESM module syntax preserved for Bun execution.
  // Bun runs directly from .ts source instead of using NestJS CLI build.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Bun runs directly from .ts source; preserve ESM syntax instead of CommonJS
    "module": "Preserve",
    "moduleResolution": "Node10",
    // Required for NestJS decorator-based dependency injection and metadata reflection
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // esModuleInterop inherited from base, but explicit here for CommonJS interop
    "esModuleInterop": true,
    // emitDecoratorMetadata synthesises require() for type imports — incompatible with verbatimModuleSyntax
    "verbatimModuleSyntax": false,
    // Bun can import .ts extensions directly
    "allowImportingTsExtensions": true
  }
}

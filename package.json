{
  "name": "salafi-durus",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20 <23",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api...",
    "dev:web": "turbo run dev --filter=web...",
    "dev:mobile": "turbo run dev --filter=mobile...",
    "dev:mobile:prebuild": "pnpm --filter mobile prebuild:clean && pnpm --filter mobile android",
    "dev:mobile:prebuild:android": "pnpm --filter mobile prebuild:clean && pnpm --filter mobile android",
    "dev:mobile:prebuild:ios": "pnpm --filter mobile prebuild:clean && pnpm --filter mobile ios",
    "dev:api+web": "pnpm --filter @sd/contracts build && turbo run dev --filter=api... --filter=web...",
    "dev:api+mobile": "turbo run dev --filter=api... --filter=mobile...",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=api...",
    "build:web": "turbo run build --filter=web...",
    "build:mobile": "turbo run build --filter=mobile...",
    "build:api+web": "turbo run build --filter=api... --filter=web...",
    "build:api+mobile": "turbo run build --filter=api... --filter=mobile...",
    "build:android": "pnpm --filter mobile build:android",
    "lint": "turbo lint",
    "lint:api+web": "turbo lint --filter=api --filter=web",
    "lint:api+mobile": "turbo lint --filter=api --filter=mobile",
    "typecheck": "turbo typecheck",
    "typecheck:affected": "turbo typecheck --affected",
    "typecheck:api+web": "turbo typecheck --filter=api --filter=web",
    "typecheck:api+mobile": "turbo typecheck --filter=api --filter=mobile",
    "test": "turbo test",
    "test:api+web": "turbo test --filter=api --filter=web",
    "test:api+mobile": "turbo test --filter=api --filter=mobile",
    "test:e2e": "turbo test:e2e",
    "test:prepush": "turbo test:prepush",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "clean": "turbo clean",
    "clean:hard": "turbo clean && rimraf node_modules **/node_modules **/.next **/dist **/build **/coverage .turbo",
    "prepare": "husky",
    "postinstall": "pnpm --filter @sd/env build && pnpm --filter @sd/design-tokens build && pnpm --filter @sd/contracts build && pnpm --filter @sd/i18n build && pnpm --filter @sd/auth-shared build && pnpm --filter ui-mobile build",
    "lint:staged": "lint-staged",
    "docs:quality": "markdownlint-cli2 README.md **/README.md docs/**/*.md AGENT.md .github/copilot-instructions.md",
    "ci:local": "pnpm lint && pnpm typecheck && pnpm test:prepush && pnpm --filter web build && pnpm docs:quality",
    "ingest:content": "pnpm --filter @sd/ingest ingest:content",
    "ingest:remove": "pnpm --filter @sd/ingest ingest:remove"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@types/react": "^19.2.9",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.53.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}

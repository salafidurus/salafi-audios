{
  "name": "salafi-durus",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@aws-sdk/client-s3": "^3.1073.0",
      "@aws-sdk/s3-request-presigner": "^3.1073.0",
      "@better-auth/expo": "1.6.18",
      "@nestjs/cli": "^11.0.21",
      "@nestjs/common": "^11.1.24",
      "@nestjs/core": "^11.1.24",
      "@nestjs/platform-express": "^11.1.24",
      "@nestjs/schematics": "^11.1.0",
      "@nestjs/terminus": "^11.1.1",
      "@nestjs/testing": "^11.1.24",
      "@prisma/adapter-pg": "^7.3.0",
      "@prisma/client": "^7.3.0",
      "@tanstack/react-query": "^5.69.0",
      "@testing-library/jest-dom": "^6.9.1",
      "@testing-library/react": "^16.3.2",
      "@testing-library/react-native": "^14.0.0",
      "@types/express": "^5.0.0",
      "@types/jest": "^29.5.14",
      "@vitejs/plugin-react": "^4.3.4",
      "better-auth": "1.6.18",
      "class-transformer": "^0.5.1",
      "class-validator": "^0.15.1",
      "eslint": "^9.39.4",
      "eslint-config-next": "16.2.9",
      "eslint-plugin-import": "^2.32.0",
      "helmet": "^8.2.0",
      "i18next": "^26.3.1",
      "jest": "^29.7.0",
      "oxfmt": "^0.56.0",
      "oxlint": "^1.70.0",
      "pg": "^8.17.2",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "react-hook-form": "^7.80.0",
      "react-i18next": "^17.0.8",
      "reflect-metadata": "^0.2.2",
      "rimraf": "^6.0.0",
      "rxjs": "^7.8.2",
      "source-map-support": "^0.5.21",
      "ts-node": "^10.9.2",
      "tsconfig-paths": "^4.2.0",
      "tsup": "^8.5.1",
      "unplugin-swc": "^1.5.1",
      "vite-tsconfig-paths": "^5.1.4",
      "vitest": "^4.1.9",
      "zustand": "^5.0.11"
    }
  },
  "scripts": {
    "dev": "turbo run dev --concurrency=25 --filter=api --filter=web --filter=native",
    "dev:api": "turbo run dev --concurrency=25 --filter=api",
    "dev:web": "turbo run dev --concurrency=25 --filter=web",
    "dev:native": "turbo run dev --concurrency=25 --filter=native",
    "dev:native:build:android": "bun run --filter native android",
    "dev:native:build:ios": "bun run --filter native ios",
    "dev:native:clean-build:android": "bun run --filter native prebuild:clean && bun run --filter native android",
    "dev:native:clean-build:ios": "bun run --filter native prebuild:clean && bun run --filter native ios",
    "build": "turbo run build",
    "build:affected": "turbo run build --affected",
    "build:api": "turbo run build --filter=api...",
    "build:web": "turbo run build --filter=web...",
    "build:native": "turbo run build --filter=native...",
    "build:android": "bun run --filter native android",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "typecheck:affected": "turbo run typecheck --affected",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:prepush": "turbo run test:prepush",
    "verify:build-configs": "bun ./scripts/verify-build-configs.mjs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "clean": "turbo run clean",
    "clean:hard": "(turbo run clean || true) && rimraf node_modules .turbo \"**/node_modules\" \"**/.next\" \"**/dist\" \"**/build\" \"**/coverage\"",
    "local-clean": "rimraf node_modules **/node_modules **/.turbo .turbo",
    "prepare": "husky",
    "postinstall": "bun ./scripts/postinstall.mjs",
    "lint:staged": "lint-staged",
    "docs:quality": "markdownlint-cli2 README.md **/README.md docs/**/*.md AGENT.md .github/copilot-instructions.md",
    "security:secrets": "secretlint \"**/*\"",
    "ci:local": "bun run verify:build-configs && bun run lint && bun run typecheck && bun run test:prepush && bun run build:affected && bun run --filter web build && bun run docs:quality",
    "ingest:content": "bun run --filter @sd/util-ingest ingest:content",
    "ingest:remove": "bun run --filter @sd/util-ingest ingest:remove",
    "doctor": "bunx react-doctor@latest",
    "native:expo:fix": "bun run --filter native expo:fix",
    "native:expo:check": "bun run --filter native expo:check"
  },
  "devDependencies": {
    "@babel/runtime": "^7.29.7",
    "@commitlint/cli": "20.3.1",
    "@commitlint/config-conventional": "21.0.2",
    "@nestjs/cli": "catalog:",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/jest": "catalog:",
    "@types/node": "26.0.0",
    "@types/react": "19.2.9",
    "@vitejs/plugin-react": "catalog:",
    "argent": "^0.1.0",
    "eslint": "catalog:",
    "eslint-plugin-import": "catalog:",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "markdownlint-cli2": "0.22.1",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "prisma": "^7.3.0",
    "react-doctor": "^0.5.8",
    "rimraf": "catalog:",
    "secretlint": "^13.0.2",
    "tsup": "catalog:",
    "tsx": "4.22.4",
    "turbo": "2.9.14",
    "typescript": "5.9.3",
    "unplugin-swc": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "bun@1.3.3"
}

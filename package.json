{
  "name": "salafi-durus",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "turbo run dev --concurrency=25 --filter=api --filter=livestreams --filter=web --filter=native",
    "dev:api": "turbo run dev --concurrency=25 --filter=api",
    "dev:livestreams": "turbo run dev --concurrency=25 --filter=livestreams",
    "dev:be": "turbo run dev --concurrency=25 --filter=api --filter=livestreams",
    "dev:web": "turbo run dev --concurrency=25 --filter=web",
    "dev:native": "turbo run dev --concurrency=25 --filter=native",
    "dev:native:build:android": "pnpm --filter native android",
    "dev:native:build:ios": "pnpm --filter native ios",
    "dev:native:clean-build:android": "pnpm --filter native prebuild:clean && pnpm --filter native android",
    "dev:native:clean-build:ios": "pnpm --filter native prebuild:clean && pnpm --filter native ios",
    "dev:be+web": "turbo run dev --concurrency=25 --filter=api --filter=livestreams --filter=web",
    "dev:be+native": "turbo run dev --concurrency=25 --filter=api --filter=livestreams --filter=native",
    "build": "turbo run build",
    "build:affected": "turbo run build --affected",
    "build:api": "turbo run build --filter=api...",
    "build:be": "turbo run build --filter=api... --filter=livestreams...",
    "build:web": "turbo run build --filter=web...",
    "build:native": "turbo run build --filter=native...",
    "build:be+web": "turbo run build --filter=api... --filter=livestreams... --filter=web...",
    "build:be+native": "turbo run build --filter=api... --filter=livestreams... --filter=native...",
    "build:android": "pnpm --filter native android",
    "lint": "turbo run lint",
    "lint:oxlint": "oxlint .",
    "lint:be+web": "turbo run lint --filter=api --filter=livestreams --filter=web",
    "lint:be+native": "turbo run lint --filter=api --filter=livestreams --filter=native",
    "typecheck": "turbo run typecheck",
    "typecheck:affected": "turbo run typecheck --affected",
    "typecheck:be+web": "turbo run typecheck --filter=api --filter=livestreams --filter=web",
    "typecheck:be+native": "turbo run typecheck --filter=api --filter=livestreams --filter=native",
    "test": "turbo run test",
    "test:be+web": "turbo run test --filter=api --filter=livestreams --filter=web",
    "test:be+native": "turbo run test --filter=api --filter=livestreams --filter=native",
    "test:e2e": "turbo run test:e2e",
    "test:prepush": "turbo run test:prepush",
    "verify:build-configs": "node ./scripts/verify-build-configs.mjs",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "clean": "turbo run clean",
    "clean:hard": "turbo run clean && rimraf node_modules **/node_modules **/.next **/dist **/build **/coverage .turbo",
    "local-clean": "rimraf node_modules **/node_modules **/.turbo .turbo",
    "prepare": "husky",
    "postinstall": "node ./scripts/postinstall.mjs",
    "lint:staged": "lint-staged",
    "docs:quality": "markdownlint-cli2 README.md **/README.md docs/**/*.md AGENT.md .github/copilot-instructions.md",
    "ci:local": "pnpm verify:build-configs && pnpm lint:oxlint && pnpm lint && pnpm typecheck && pnpm test:prepush && pnpm build:affected && pnpm --filter web build && pnpm docs:quality",
    "ingest:content": "pnpm --filter @sd/util-ingest ingest:content",
    "ingest:remove": "pnpm --filter @sd/util-ingest ingest:remove",
    "doctor": "npx react-doctor@latest",
    "native:expo:fix": "pnpm --filter native exec expo install --check",
    "native:expo:check": "pnpm --filter native exec expo-doctor"
  },
  "devDependencies": {
    "@commitlint/cli": "20.3.1",
    "@commitlint/config-conventional": "20.3.1",
    "@types/jest": "30.0.0",
    "@types/node": "22.10.7",
    "@types/react": "19.2.9",
    "@typescript-eslint/eslint-plugin": "8.53.1",
    "@typescript-eslint/parser": "8.53.1",
    "argent": "^0.1.0",
    "eslint": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "globals": "catalog:",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "markdownlint-cli2": "0.22.1",
    "oxlint": "catalog:",
    "prettier": "catalog:",
    "react-doctor": "^0.5.1",
    "rimraf": "catalog:",
    "tsx": "4.22.4",
    "turbo": "2.9.14",
    "typescript": "5.9.3",
    "typescript-eslint": "catalog:"
  }
}

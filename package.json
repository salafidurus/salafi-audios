{
  "name": "salafi-durus",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@better-auth/expo": "1.6.23",
      "@prisma/adapter-pg": "^7.3.0",
      "@prisma/client": "^7.3.0",
      "@tanstack/react-query": "^5.101.2",
      "@testing-library/react": "^16.3.2",
      "better-auth": "1.6.23",
      "eslint": "^9.7.0",
      "i18next": "^26.3.6",
      "pg": "^8.17.2",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "react-i18next": "^17.0.9",
      "rimraf": "^6.0.0",
      "tsup": "^8.5.1",
      "vitest": "^4.1.10",
      "zod": "^4.4.3",
      "zustand": "^5.0.11",
      "@types/node": "^26.0.0",
      "@types/react": "~19.2.14",
      "dotenv": "^17.4.2"
    }
  },
  "scripts": {
    "catalog": "bun ./scripts/catalog/cli.ts",
    "dev": "turbo run dev --filter=api --filter=web --filter=native",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "dev:native": "turbo run dev --filter=native",
    "dev:api+web": "turbo run dev --filter=api --filter=web",
    "dev:native:build:android": "bun run --filter native android",
    "dev:native:build:ios": "bun run --filter native ios",
    "dev:native:clean-build:android": "bun run --filter native prebuild:clean && bun run --filter native android",
    "dev:native:clean-build:ios": "bun run --filter native prebuild:clean && bun run --filter native ios",
    "build": "turbo run build",
    "build:affected": "turbo run build --affected",
    "build:api": "turbo run build --filter=api...",
    "build:web": "turbo run build --filter=web...",
    "build:native": "turbo run build --filter=native...",
    "build:android": "bun run --filter native android",
    "lint": "turbo run lint && oxlint scripts && oxfmt --check scripts",
    "typecheck": "turbo run typecheck",
    "typecheck:affected": "turbo run typecheck --affected",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:prepush": "turbo run test:prepush",
    "verify:build-configs": "bun ./scripts/verify-build-configs.mjs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "clean": "turbo run clean",
    "clean:hard": "(turbo run clean || true) && rimraf node_modules .turbo \"**/node_modules\" \"**/.next\" \"**/dist\" \"**/build\" \"**/coverage\"",
    "local-clean": "rimraf node_modules **/node_modules **/.turbo .turbo",
    "prepare": "husky",
    "postinstall": "bun ./scripts/postinstall.mjs",
    "lint:staged": "lint-staged",
    "docs:quality": "markdownlint-cli2 README.md **/README.md docs/**/*.md AGENT.md .github/copilot-instructions.md '!.serena/**/*.md'",
    "security:secrets": "secretlint \"**/*\"",
    "ci:local": "bun run catalog && bun run verify:build-configs && bun run lint && bun run typecheck && bun run test:prepush && bun run build:affected && bun run --filter web build && bun run docs:quality",
    "doctor": "bunx react-doctor@latest",
    "native:expo:fix": "bun run --filter native expo:fix",
    "native:expo:check": "bun run --filter native expo:check"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "bun-types": "^1.3.14",
    "eslint": "catalog:",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "markdownlint-cli2": "0.23.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-plugin-react-doctor": "^0.7.8",
    "react": "catalog:",
    "react-doctor": "^0.7.8",
    "rimraf": "catalog:",
    "secretlint": "^13.0.2",
    "tsup": "catalog:",
    "tsx": "4.23.1",
    "turbo": "2.10.5",
    "typescript": "5.9.3",
    "unplugin-swc": "^1.5.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": "1.3.14",
    "node": "22.x"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "@sentry/cli"
  ]
}

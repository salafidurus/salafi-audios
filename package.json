{
  "name": "salafi-durus",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20 <23",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "pnpm --filter @sd/design-tokens build && turbo run dev --concurrency=25 --filter=api --filter=web --filter=native",
    "dev:api": "pnpm --filter @sd/core-db build && turbo run dev --concurrency=25 --filter=api",
    "dev:web": "pnpm --filter @sd/design-tokens build && turbo run dev --concurrency=25 --filter=web",
    "dev:native": "pnpm --filter @sd/design-tokens build && turbo run dev --concurrency=25 --filter=native",
    "dev:native:prebuild": "pnpm --filter native prebuild:clean && pnpm --filter native android",
    "dev:native:prebuild:android": "pnpm --filter native prebuild:clean && pnpm --filter native android",
    "dev:native:prebuild:ios": "pnpm --filter native prebuild:clean && pnpm --filter native ios",
    "dev:api+web": "pnpm --filter @sd/design-tokens build && pnpm --filter @sd/core-db build && turbo run dev --concurrency=25 --filter=api --filter=web",
    "dev:api+native": "pnpm --filter @sd/design-tokens build && pnpm --filter @sd/core-db build && turbo run dev --concurrency=25 --filter=api --filter=native",
    "dev:livestreams": "pnpm --filter @sd/core-db build && turbo run dev --concurrency=25 --filter=livestreams",
    "build": "turbo run build",
    "build:affected": "turbo run build --affected",
    "build:api": "turbo run build --filter=api...",
    "build:web": "turbo run build --filter=web...",
    "build:native": "turbo run build --filter=native...",
    "build:api+web": "turbo run build --filter=api... --filter=web...",
    "build:api+native": "turbo run build --filter=api... --filter=native...",
    "build:android": "pnpm --filter native build:android",
    "lint": "turbo lint",
    "lint:api+web": "turbo lint --filter=api --filter=web",
    "lint:api+native": "turbo lint --filter=api --filter=native",
    "typecheck": "turbo typecheck",
    "typecheck:affected": "turbo typecheck --affected",
    "typecheck:api+web": "turbo typecheck --filter=api --filter=web",
    "typecheck:api+native": "turbo typecheck --filter=api --filter=native",
    "test": "turbo test",
    "test:api+web": "turbo test --filter=api --filter=web",
    "test:api+native": "turbo test --filter=api --filter=native",
    "test:e2e": "turbo test:e2e",
    "test:prepush": "turbo test:prepush",
    "verify:build-configs": "node ./scripts/verify-build-configs.mjs",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "clean": "turbo clean",
    "clean:hard": "turbo clean && rimraf node_modules **/node_modules **/.next **/dist **/build **/coverage .turbo",
    "local-clean": "rimraf node_modules **/node_modules **/.turbo .turbo",
    "prepare": "husky",
    "postinstall": "node ./scripts/postinstall.mjs",
    "lint:staged": "lint-staged",
    "docs:quality": "markdownlint-cli2 README.md **/README.md docs/**/*.md AGENT.md .github/copilot-instructions.md",
    "ci:local": "pnpm verify:build-configs && pnpm lint && pnpm typecheck && pnpm test:prepush && pnpm build:affected && pnpm --filter web build && pnpm docs:quality",
    "ingest:content": "pnpm --filter @sd/util-ingest ingest:content",
    "ingest:remove": "pnpm --filter @sd/util-ingest ingest:remove",
    "doctor": "npx react-doctor@latest"
  },
  "devDependencies": {
    "@commitlint/cli": "20.3.1",
    "@commitlint/config-conventional": "20.3.1",
    "@types/react": "19.2.9",
    "@typescript-eslint/eslint-plugin": "8.53.1",
    "@typescript-eslint/parser": "8.53.1",
    "argent": "^0.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "10.0.0",
    "eslint-plugin-import": "2.32.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "markdownlint-cli2": "0.18.1",
    "prettier": "3.3.3",
    "react-doctor": "^0.2.14",
    "rimraf": "6.0.0",
    "tsx": "4.21.0",
    "turbo": "2.9.14",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [],
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "@types/react": "19.2.9"
    }
  }
}

{
  // Shared base compiler options for every workspace. Family presets
  // (tsconfig.packages.json, tsconfig.nest.json) and apps extend this file.
  // Updated to align with Bun's recommended TypeScript configuration.
  "compilerOptions": {
    // Bun prefers ESNext for latest features and optimizations
    "target": "ESNext",
    "lib": ["ESNext"],
    // Let bundlers/runtimes handle module format — Bun's preferred approach
    "module": "Preserve",
    "moduleResolution": "bundler",
    // Modern JSX transform (can be overridden per-app)
    "jsx": "react-jsx",
    "strict": true,
    // Skip .d.ts validation in node_modules — speeds up compilation significantly
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    // Forces explicit `import type` for type-only imports — required for correct bundler output
    "verbatimModuleSyntax": true,
    // Array index / object key access returns T | undefined — prevents common runtime crashes
    "noUncheckedIndexedAccess": true,
    // Treat every file as a module — avoids accidental global scripts under modern tooling
    "moduleDetection": "force",
    // Each file must be transpilable in isolation — required by modern bundlers
    "isolatedModules": true,
    // Bun supports importing .ts extensions directly
    "allowImportingTsExtensions": true,
    // Better CommonJS interop for mixed module systems
    "allowSyntheticDefaultImports": true,
    // Default to typecheck-only; build configs override this
    "noEmit": true,
    // Include Bun and Node type definitions
    "types": ["bun-types", "node"],
    // Stricter checks - gradually enable these for better code quality
    // For immediate strict mode, extend tsconfig.strict.json instead
    "noImplicitReturns": true,
    "noImplicitOverride": true
    // Disabled by default (enable per-package when ready):
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noPropertyAccessFromIndexSignature": true
  }
}

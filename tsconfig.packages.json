{
  // Bundler-first preset for shared libraries and bundler-consumed apps (web, native).
  // These are always consumed through a bundler (Metro/Next/tsup), never run directly by Node.
  // Most settings now inherited from tsconfig.base.json (module, moduleResolution, isolatedModules, noEmit).
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Many React Native / Expo packages only ship CJS — enables default imports from them
    "esModuleInterop": true,
    // Include test globals, Node types, and Bun types
    "types": ["bun-types", "node"]
  }
}

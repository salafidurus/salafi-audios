#!/bin/sh

# react-doctor hook start
react_doctor_scan_staged_files() {
  bunx react-doctor@latest --staged --blocking warning --max-duration 120
}

react_doctor_output=$(mktemp "${TMPDIR:-/tmp}/react-doctor-hook.XXXXXX")
if react_doctor_scan_staged_files > "$react_doctor_output" 2>&1; then
  rm -f "$react_doctor_output"
else
  cat "$react_doctor_output" >&2
  rm -f "$react_doctor_output"
  printf '%s\n' "React Doctor found staged regressions. Commit blocked." "Run: bunx react-doctor --staged --blocking warning" >&2
  exit 1
fi
# react-doctor hook end

# semgrep hook start
semgrep_scan_staged_files() {
  if command -v semgrep >/dev/null 2>&1; then
    printf "pre-commit: running semgrep on staged changes...\n"
    staged_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)
    if [ -n "$staged_files" ]; then
      semgrep scan --config .semgrep-rules.json --metrics=off --quiet --error --skip-unknown-extensions $staged_files
    fi
    return
  fi

  printf '%s\n' "WARNING: semgrep CLI is not installed. Static analysis check skipped."
  printf '%s\n' "To install: brew install semgrep (macOS) or pip install semgrep (Windows/Linux)"
}

semgrep_output=$(mktemp "${TMPDIR:-/tmp}/semgrep-hook.XXXXXX")
if semgrep_scan_staged_files > "$semgrep_output" 2>&1; then
  rm -f "$semgrep_output"
else
  cat "$semgrep_output" >&2
  rm -f "$semgrep_output"
  printf '%s\n' "Semgrep check failed. Commit blocked." >&2
  exit 1
fi
# catalog fix start
printf "pre-commit: running catalog auto-fixer...\n"
bun run catalog fix

# Stage any package.json files modified by the fixer
git diff --name-only | grep 'package.json' | while read -r file; do
  git add "$file"
done

# Run check to verify no outstanding blocking issues remain
if ! bun run catalog; then
  printf "\x1b[31mCatalog validation failed. Commit blocked.\x1b[0m\n" >&2
  exit 1
fi
# catalog fix end

bun run lint:staged


ZERO_SHA="0000000000000000000000000000000000000000"

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "$local_sha" ] || [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi

  printf "pre-push: validating changed packages...\n"
  break
done || {
  printf "pre-push: no branch updates to validate\n"
  exit 0
}

pnpm verify:build-configs
pnpm turbo lint typecheck test:prepush build --affected --continue

if git diff --quiet origin/main...HEAD -- ':(glob)apps/web/**' ':(glob)packages/core-api/**' ':(glob)packages/core-contracts/**' ':(glob)packages/core-i18n/**' ':(glob)packages/design-tokens/**' ':(glob)packages/domain-account/**' ':(glob)packages/domain-audio/**' ':(glob)packages/domain-content/**' ':(glob)packages/domain-live/**' ':(glob)packages/domain-search/**' ':(glob)packages/util-config/**'; then
  printf "pre-push: skipping web e2e (no web-affecting changes)\n"
else
  printf "pre-push: running web e2e\n"
  pnpm turbo test:e2e --filter=web
fi

if git diff --quiet origin/main...HEAD -- README.md ':(glob)docs/**/*.md' AGENT.md AGENTS.md .github/copilot-instructions.md; then
  printf "pre-push: skipping docs:quality (no docs changes)\n"
else
  pnpm docs:quality
fi

if git diff --quiet origin/main...HEAD -- packages/core-db/prisma/schema.prisma packages/core-db/prisma.config.ts packages/core-db/package.json; then
  printf "pre-push: skipping prisma:generate (no db schema/config changes)\n"
else
  pnpm --filter @sd/core-db prisma:generate
fi

if git diff --quiet origin/main...HEAD -- ':(glob)apps/native/**'; then
  printf "pre-push: skipping expo-doctor (no native changes)\n"
else
  printf "pre-push: running expo-doctor\n"
  pnpm --filter native exec expo-doctor
fi


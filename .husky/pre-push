ZERO_SHA="0000000000000000000000000000000000000000"

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "$local_sha" ] || [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi

  printf "pre-push: validating changed packages...\n"
  break
done || {
  printf "pre-push: no branch updates to validate\n"
  exit 0
}

pnpm verify:build-configs
pnpm turbo lint typecheck test:prepush --affected
pnpm turbo build --affected

if git diff --quiet origin/main...HEAD -- ':(glob)apps/web/**' ':(glob)packages/shared/**' ':(glob)packages/design-tokens/**' ':(glob)packages/core-config/**' ':(glob)packages/core-styles/**' ':(glob)packages/core-auth/**' ':(glob)packages/feature-auth/**' ':(glob)packages/feature-navigation/**' ':(glob)packages/feature-search/**'; then
  printf "pre-push: skipping web e2e (no web-affecting changes)\n"
else
  printf "pre-push: running web e2e\n"
  pnpm --filter web test:e2e
fi

if git diff --quiet origin/main...HEAD -- README.md ':(glob)docs/**/*.md' AGENT.md AGENTS.md .github/copilot-instructions.md; then
  printf "pre-push: skipping docs:quality (no docs changes)\n"
else
  pnpm docs:quality
fi

if git diff --quiet origin/main...HEAD -- packages/db/prisma/schema.prisma packages/db/prisma.config.ts packages/db/package.json; then
  printf "pre-push: skipping prisma:generate (no db schema/config changes)\n"
else
  pnpm --filter @sd/db prisma:generate
fi

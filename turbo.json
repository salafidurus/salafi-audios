{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "ui": "tui",
  // Prisma client generation needs DB URLs at build time; pass them through to all tasks
  "globalPassThroughEnv": ["DIRECT_DB_URL", "DATABASE_URL"],
  "tasks": {
    "dev": {
      // Build workspace dependencies first (cached) so dist/ exports resolve
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      // Topological: packages build before apps that depend on them
      "dependsOn": ["^build"],
      // Env files included because Next.js and NestJS inline env vars at build time
      "inputs": ["$TURBO_DEFAULT$", ".env*", "tsconfig*.json", "next.config.*"],
      "outputs": ["dist/**", "build/**", ".next/**", "lib/**", "generated/**", "src/generated/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      // Include shared ESLint config so lint re-runs when rules change
      "inputs": [
        "$TURBO_DEFAULT$",
        ".eslintrc*",
        "eslint.config.*",
        "packages/util-config/eslint/**"
      ],
      "outputs": []
    },
    "typecheck": {
      // ^build so dependencies' emitted .d.ts exist before we typecheck. apps/api uses
      // classic "node" moduleResolution, which ignores package "exports" and reads the
      // top-level "types": "./dist/index.d.ts" — that file must be built first.
      "dependsOn": ["^build", "^typecheck"],
      // Include shared tsconfig so typecheck re-runs when compiler options change
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json", "packages/util-config/tsconfig/**"],
      // Most packages emit nothing from typecheck (tsc --noEmit); declaring outputs here
      // produced "no output files found" warnings. Prisma generation is scoped to the
      // @sd/core-db override below.
      "outputs": []
    },
    // core-db's pretypecheck runs `prisma generate`, so its typecheck genuinely emits the
    // client. Cache it for downstream consumers.
    "@sd/core-db#typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json", "packages/util-config/tsconfig/**"],
      "outputs": ["generated/**", "src/generated/**"]
    },
    "test": {
      "dependsOn": ["^build", "^test"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/*.spec.*",
        "**/*.test.*",
        "jest.config.*",
        "**/jest.config.*"
      ],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "e2e/**/*.ts"],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": true,
      "env": ["CI", "PW_SKIP_WEB_BUILD"]
    },
    "test:prepush": {
      "dependsOn": ["^build", "^test:prepush"],
      "cache": true
    },
    // Generates OpenAPI spec from NestJS decorators for contract-first API development
    "openapi": {
      "dependsOn": ["^openapi"],
      "inputs": ["$TURBO_DEFAULT$", "src/**", "package.json", "tsconfig*.json"],
      "outputs": ["openapi.json"]
    },
    // Builds shared contract types (DTOs, response shapes) consumed by web and mobile
    "contract": {
      "dependsOn": ["^contract"],
      "inputs": ["$TURBO_DEFAULT$", "src/**", "package.json", "tsconfig*.json"],
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    }
  }
}

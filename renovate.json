{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":separatePatchReleases", ":separateMultipleMinorReleases"],
  "timezone": "UTC",
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    ".agents/**",
    ".gemini/**",
    ".worktrees/**",
    ".worktree/**"
  ],
  "rebaseWhen": "behind-base-branch",
  "prConcurrentLimit": 20,
  "prHourlyLimit": 10,
  "packageRules": [
    {
      "description": "Ignore Expo, React, React Native, NestJS, Next.js, Prisma, and other locked infrastructure deps",
      "matchPackageNames": [
        "expo",
        "react",
        "react-dom",
        "next",
        "prisma",
        "turbo",
        "typescript",
        "better-auth",
        "expo-{/,}**",
        "@expo/{/,}**",
        "eslint-config-expo{/,}**",
        "@types/react{/,}**",
        "@types/react-dom{/,}**",
        "react-native{/,}**",
        "react-native-{/,}**",
        "@react-native/{/,}**",
        "@react-navigation/{/,}**",
        "@prisma/{/,}**",
        "@nestjs/{/,}**",
        "@better-auth/{/,}**"
      ],
      "enabled": false
    },
    {
      "description": "Group dev-tooling patches & minors with automerge",
      "matchPackageNames": [
        "eslint",
        "prettier",
        "lint-staged",
        "husky",
        "commitlint",
        "oxlint",
        "react-doctor",
        "eslint-{/,}**",
        "@eslint/{/,}**",
        "@commitlint/{/,}**",
        "oxlint-{/,}**",
        "@oxlint/{/,}**"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev-tooling",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group test-tooling patches & minors with automerge",
      "matchPackageNames": [
        "jest",
        "ts-jest",
        "playwright",
        "jest-{/,}**",
        "@jest/{/,}**",
        "@testing-library/{/,}**",
        "@playwright/{/,}**"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "test-tooling",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group Vitest and Vite ecosystem (including majors) with automerge",
      "matchPackageNames": [
        "vitest",
        "vite-tsconfig-paths",
        "unplugin-swc",
        "vitest-{/,}**",
        "@vitest/{/,}**",
        "@vitejs/{/,}**"
      ],
      "groupName": "vitest",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },

    {
      "description": "Group GitHub Actions updates with automerge",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Ensure vulnerability fixes bypass the schedule and are sent immediately",
      "matchUpdateTypes": ["security"],
      "schedule": ["at any time"]
    }
  ]
}

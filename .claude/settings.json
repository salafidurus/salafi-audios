{
  "mcpServers": {
    "tailwindcss": {},
    "server-github": {},
    "in-memoria": {},
    "sequential-thinking": {},
    "context7": {},
    "server-memory": {},
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "prisma": {
      "command": "npx",
      "args": ["-y", "prisma", "mcp"]
    }
  },
  "instructions": [
    "Read the relevant AGENT.md file before working in any workspace (apps/api/AGENT.md, apps/web/AGENT.md, apps/mobile/AGENT.md, or packages/*/AGENT.md)"
  ],
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(**/*.ts)",
      "Write(**/*.tsx)",
      "Write(**/*.js)",
      "Write(**/*.jsx)",
      "Write(**/*.json)",
      "Write(**/*.css)",
      "Write(**/*.md)",
      "Write(**/*.mdx)",
      "Bash(grep *)",
      "Bash(grep:*)",
      "Bash(cat *)",
      "Bash(cat:*)",
      "Bash(ls *)",
      "Bash(ls:*)",
      "Bash(find *)",
      "Bash(find:*)",
      "Bash(echo *)",
      "Bash(echo:*)",
      "Bash(pwd *)",
      "Bash(pwd:*)",
      "Bash(which *)",
      "Bash(which:*)",
      "Bash(whoami *)",
      "Bash(whoami:*)",
      "Bash(wc *)",
      "Bash(wc:*)",
      "Bash(head *)",
      "Bash(head:*)",
      "Bash(tail *)",
      "Bash(tail:*)",
      "Bash(sort *)",
      "Bash(sort:*)",
      "Bash(uniq *)",
      "Bash(uniq:*)",
      "Bash(cut *)",
      "Bash(cut:*)",
      "Bash(awk *)",
      "Bash(awk:*)",
      "Bash(sed *)",
      "Bash(sed:*)",
      "Bash(tr *)",
      "Bash(tr:*)",
      "Bash(diff *)",
      "Bash(diff:*)",
      "Bash(stat *)",
      "Bash(stat:*)",
      "Bash(file *)",
      "Bash(file:*)",
      "Bash(type *)",
      "Bash(type:*)",
      "Bash(env *)",
      "Bash(env:*)",
      "Bash(printenv *)",
      "Bash(printenv:*)",
      "Bash(date *)",
      "Bash(date:*)",
      "Bash(tree *)",
      "Bash(tree:*)",
      "Bash(du *)",
      "Bash(du:*)",
      "Bash(df *)",
      "Bash(df:*)",
      "Bash(ps *)",
      "Bash(ps:*)",
      "Bash(git *)",
      "Bash(git:*)",
      "Bash(node *)",
      "Bash(node:*)",
      "Bash(npm *)",
      "Bash(npm:*)",
      "Bash(tsc *)",
      "Bash(tsc:*)",
      "Bash(cd *)",
      "Bash(cd:*)",
      "Bash(npx *)",
      "Bash(npx:*)",
      "Bash(netstat *)",
      "Bash(netstat:*)",
      "Bash(jobs *)",
      "Bash(jobs:*)",
      "Bash(curl *)",
      "Bash(curl:*)",
      "Bash(rm -rf **/.next*)",
      "Bash(rm -rf **/.expo*)",
      "Bash(rm -rf **/node_modules*)",
      "Bash(rm -rf **/.turbo*)",
      "Bash(rm -rf **/dist*)",
      "Bash(rm -rf **/.cache*)",
      "Bash(rm -rf **/out*)",
      "Bash(rm -rf **/build*)",
      "Bash(rm -rf **/coverage*)",
      "Bash(pnpm install)",
      "Bash(pnpm install *)",
      "Bash(pnpm --filter * add *)"
    ],
    "ask": [
      "Bash(npx kill-port*)",
      "Bash(git push *)",
      "Bash(git restore *)",
      "Bash(git reset *)",
      "Bash(rm *)",
      "Write(**/*.env*)"
    ],
    "deny": [
      "Bash(curl * -d *)",
      "Bash(curl * --data*)",
      "Bash(curl * -X POST*)",
      "Bash(curl * -X PUT*)",
      "Bash(curl * -X DELETE*)",
      "Bash(curl * -T *)",
      "Bash(pnpm add *)"
    ]
  }
}
